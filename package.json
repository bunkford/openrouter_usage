{
  "name": "openrouter-usage",
  "displayName": "OpenRouter Usage",
  "description": "Display OpenRouter API usage in the status bar",
  "version": "1.0.1",
  "publisher": "bunkford",
  "repository": {
    "type": "git",
    "url": "https://github.com/bunkford/openrouter_usage"
  },
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.120.0"
  },
  "categories": [
    "Other",
    "Data Science"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "openrouter-usage.refresh",
        "title": "Refresh OpenRouter Usage",
        "icon": "$(refresh)"
      },
      {
        "command": "openrouter-usage.showDetails",
        "title": "Show OpenRouter Usage Details"
      },
      {
        "command": "openrouter-usage.openSettings",
        "title": "OpenRouter: Open Settings"
      }
    ],
    "menus": {
      "statusBar/statusIndicator": [
        {
          "command": "openrouter-usage.showDetails",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "OpenRouter Usage",
      "properties": {
        "openrouter.apiKey": {
          "type": "string",
          "default": "",
          "description": "OpenRouter API key (sk-or-v1-...). Get one at openrouter.ai/settings/keys",
          "scope": "machine"
        },
        "openrouter.endpoint": {
          "type": "string",
          "default": "https://openrouter.ai",
          "description": "OpenRouter API endpoint (proxy or direct)",
          "scope": "machine"
        },
        "openrouter.refreshInterval": {
          "type": "number",
          "default": 300,
          "description": "Auto-refresh interval in seconds (0 to disable)",
          "scope": "machine"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.120.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "esbuild": "^0.27.3",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
